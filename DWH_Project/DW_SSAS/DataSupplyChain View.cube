  <MdxScripts>
    <MdxScript dwd:design-time-name="13f2f70d-9406-4083-9187-c91e3e73353a">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Days For Shipping Real]
 AS IIF(
    [Measures].[Fact Customer Experience Count] = 0, 
    NULL, 
    [Measures].[Days For Shipping Real] / [Measures].[Fact Customer Experience Count]
), 
FORMAT_STRING = "0.00", 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Shipping Delay Days]
 AS IIF(
    [Measures].[Fact Customer Experience Count] = 0, 
    NULL, 
    [Measures].[Shipping Delay Days] / [Measures].[Fact Customer Experience Count]
), 
FORMAT_STRING = "0.00", 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Is Late]
 AS IIF(
    [Measures].[Fact Customer Experience Count] = 0, 
    NULL, 
    [Measures].[Is Late] / [Measures].[Fact Customer Experience Count]
), 
FORMAT_STRING = "Percent", 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg On Time Flag]
 AS IIF(
    [Measures].[Fact Customer Experience Count] = 0, 
    NULL, 
    [Measures].[On Time Flag] / [Measures].[Fact Customer Experience Count]
), 
FORMAT_STRING = "Percent", 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Days For Shipment Scheduled]
 AS IIF(
    [Measures].[Fact Customer Experience Count] = 0, 
    NULL, 
    [Measures].[Days For Shipment Scheduled] / [Measures].[Fact Customer Experience Count]
), 
FORMAT_STRING = "0.00", 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>